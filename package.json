{
  "name": "aienvmap",
  "version": "0.2.0",
  "description": "Dependency-free environment map and explicit change handoff for AI coding agents sharing a repository or machine.",
  "type": "module",
  "bin": {
    "aienvmap": "bin/aienvmap.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soovwv/aienvmap.git"
  },
  "bugs": {
    "url": "https://github.com/soovwv/aienvmap/issues"
  },
  "homepage": "https://github.com/soovwv/aienvmap#readme",
  "files": [
    "bin",
    "src",
    "scripts/performance-check.mjs",
    "scripts/contract-check.mjs",
    "scripts/apm-consumer-check.mjs",
    "scripts/installed-package-check.mjs",
    "contracts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "BUGFIXES.md",
    "CONTRIBUTING.md",
    "CASE_REVIEW.md",
    "SECURITY.md",
    "TROUBLESHOOTING.md",
    "ROADMAP.md",
    "SCORECARD.md",
    "MARKET.md",
    "VALIDATION.md",
    "TESTING.md",
    "AI_TESTING.md",
    "TESTER_INVITE.md",
    "RELEASE_NOTES_0.2.0.md",
    "action.yml",
    "examples",
    ".agents",
    ".apm",
    "apm.yml"
  ],
  "scripts": {
    "test": "node --test",
    "pack:dry": "npm pack --dry-run",
    "pack:install-check": "node scripts/installed-package-check.mjs",
    "smoke": "node bin/aienvmap.js --version && node bin/aienvmap.js --help",
    "perf:check": "node scripts/performance-check.mjs",
    "contract:check": "node scripts/contract-check.mjs",
    "text:check": "node scripts/text-policy-check.mjs",
    "demo:conflict": "node examples/multi-agent-conflict-demo.mjs",
    "release:check": "npm run text:check && npm test && npm run smoke && npm run contract:check && npm run perf:check && npm run demo:conflict && npm run pack:dry && npm run pack:install-check"
  },
  "keywords": [
    "ai",
    "ai-workspace",
    "ai-agents",
    "ai-coding",
    "coordination",
    "workspace-coordination",
    "multi-agent",
    "shared-environment",
    "environment",
    "env-map",
    "environment-map",
    "version-drift",
    "sbom",
    "light-sbom",
    "dependency-coordination",
    "runtime",
    "agent",
    "agentic",
    "devops",
    "codex",
    "claude",
    "gemini"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  }
}
